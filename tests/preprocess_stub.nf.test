nextflow_pipeline {

    name "Test preprocess workflow stub"
    script "../main.nf"
    tag "stub"



    test("-profile test, stub") {
        options "-stub"

        when {
            params {
                outdir = "$outputDir"
                input = 'https://raw.githubusercontent.com/nf-core/test-datasets/lsmquant/test_data/samplesheets/sample_sheet.csv'
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def json_files = getAllFilesFromDir(params.outdir, include: ['**/*.json'])
            assert workflow.success
            assertAll(
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_lsmquant_software_mqc_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name.isEmpty() ? 'No stable paths' : stable_name
                ).match()}
            )
        }

    }

}
