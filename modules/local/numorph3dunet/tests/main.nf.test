nextflow_process {

    name "Test Process NUMORPH3DUNET"
    script "../main.nf"
    process "NUMORPH3DUNET"

    tag "modules"
    tag "modules_"
    tag "numorph3dunet"
    tag "gpu"
    profile "docker,gpu"

    config './nextflow.config'

    test("Numorph3DUnet test - tif") {

        setup {
            run ("UNZIPFILES") {
                script "../../../nf-core/unzipfiles/main.nf"
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file(params.pipelines_testdata_base_path + '/test_data/unet_test_images.zip'))
                    ])
                """
                }
            }
        }

        when {
            params {
                outdir = "$workDir/output"
            }
            process {
                """
                input[0] = UNZIPFILES.out.files.map { meta, unzipped ->
                    tuple(
                    meta,
                    unzipped,
                    file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                }
                input[1] = Channel.fromPath(params.model_file, checkIfExists: !params.model_file.startsWith('http'))
                """
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            assert workflow.success
            assertAll(
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name.isEmpty() ? 'No stable paths' : stable_name
                ).match()}
            )
        }

    }
}
