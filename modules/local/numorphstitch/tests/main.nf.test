nextflow_process {
    name "Test Process Numorphstitch"
    script "../main.nf"
    process "NUMORPHSTITCH"

    test("numorph stitch test") {
        setup {
            run ("UNZIP") {
                script "../../../nf-core/unzip/main.nf"
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'))
                    ])
                    """
                }
            }
        }
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = UNZIP.out.unzipped_archive
                    .map { meta, unzipped_archive ->
                        [
                            meta,
                            unzipped_archive,
                            file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'),
                            [],
                            []
                        ]
                    }
                """
            }
        }
        then {
            // Get the directory paths
            def variablesDir = process.out.variables_stitched.get(0).get(1)
            def samplesDir = process.out.stitched.get(0).get(1)

            // Use getAllFilesFromDir to get relative file paths
            def variablesFiles = getAllFilesFromDir(variablesDir, relative: true, includeDir: false)
            def samplesFiles = getAllFilesFromDir(samplesDir, relative: true, includeDir: false)
            assertAll (
                { assert process.success },             // Check process completed successfully
                { assert file(process.out.NM_variable.get(0).get(1)).exists() : "NM_variables.mat file does not exist" },
                { assert variablesFiles.size() == 6 },
                { assert samplesFiles.size() == 36 },
                { assert snapshot(
                    variablesFiles,
                    samplesFiles,
                    process.out.versions
                ).match()}
            )
        }
    }

    test("numorph stitch stub test") {
        options '-stub'
        setup {
            run ("UNZIP") {
                script "../../../nf-core/unzip/main.nf"
                options '-stub'
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'))
                    ])
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = UNZIP.out.unzipped_archive
                    .map { meta, unzipped_archive ->
                        [
                            meta,
                            unzipped_archive,
                            file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'),
                            [], // variables
                            []  // NM_variable
                        ]
                    }
                """
            }
        }
        then {
            assert process.success              // Check process completed successfully
            assert snapshot(process.out).match() // Validate outputs match expected snapshot
        }
    }

}
