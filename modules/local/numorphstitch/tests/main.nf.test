nextflow_process {
    name "Test Process Numorphstitch"
    script "../main.nf"
    process "NUMORPHSTITCH"

    test("Numorphstitch test") {
        setup {
            run ("UNZIP") {
                script "../../../nf-core/unzip/main.nf"
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'))
                    ])
                    """
                }
            }
        }
        when {
            params {
                outdir = "$workDir/output"
            }
            process {
                """
                input[0] = UNZIP.out.unzipped_archive.map { meta, unzipped_archive ->
                    tuple(
                    meta,
                    unzipped_archive,
                    file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                } //
                input[1] = UNZIP.out.unzipped_archive.map {[]}
                input[2] = UNZIP.out.unzipped_archive.map {[]}
                input[3] = UNZIP.out.unzipped_archive.map {[]}
                input[4] = UNZIP.out.unzipped_archive.map {[]}
                input[5] = UNZIP.out.unzipped_archive.map {[]}
                input[6] = UNZIP.out.unzipped_archive.map {[]}
                """

            }
        }
        then {
            assert process.success              // Check process completed successfully
            assert snapshot(process.out).match() // Validate outputs match expected snapshot
        }
    }

    test("Numorphstitch stub test") {
        options '-stub'
        setup {
            run ("UNZIP") {
                script "../../../nf-core/unzip/main.nf"
                options '-stub'
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'))
                    ])
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = UNZIP.out.unzipped_archive.map { meta, unzipped_archive ->
                    tuple(
                    meta,
                    unzipped_archive,
                    file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                } //
                input[1] = UNZIP.out.unzipped_archive.map {[]}
                input[2] = UNZIP.out.unzipped_archive.map {[]}
                input[3] = UNZIP.out.unzipped_archive.map {[]}
                input[4] = UNZIP.out.unzipped_archive.map {[]}
                input[5] = UNZIP.out.unzipped_archive.map {[]}
                input[6] = UNZIP.out.unzipped_archive.map {[]}
                """
            }
        }
        then {
            assert process.success              // Check process completed successfully
            assert snapshot(process.out).match() // Validate outputs match expected snapshot
        }
    }

}
