{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/lsmquant/master/assets/schema_input.json",
    "title": "nf-core/lsmquant pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample_id": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "img_directory": {
                "type": "string",
                "format": "directory-path",
                "exists": true,
                "errorMessage": "Image directory must be provided and must exist"
            },
            "parameter_file": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.csv$",
                "errorMessage": "Parameter file must be provided, must exist and must be a CSV file"
            }
        },
        "required": ["sample_id", "img_directory", "parameter_file"]
    }
}
